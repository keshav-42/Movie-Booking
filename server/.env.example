# ---- Database ----
# MongoDB connection string WITHOUT a trailing db name (code appends /quickshow)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# ---- Clerk (auth) ----
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ---- TMDB (movie data) ----
# A v4 "Read Access Token" (used as a Bearer token) from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v4_read_access_token

# ---- Stripe (payments) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Email (Brevo SMTP relay via nodemailer) ----
SMTP_USER=your_brevo_login
SMTP_PASS=your_brevo_smtp_key
SENDER_EMAIL=you@example.com

# ---- Frontend URL (used in email links; set to your deployed client URL) ----
CLIENT_URL=http://localhost:5173

# ---- Ticketmaster Discovery API (live events feed for admin > Add Events) ----
# Free key: https://developer.ticketmaster.com — without it a bundled sample
# feed is served so the flow still works.
TICKETMASTER_API_KEY=

# ---- Demo account (powers the "Try Demo" one-click login) ----
# Clerk user id of the shared demo user. Optional — the code falls back to a
# built-in demo user id, so leave blank to use the default.
DEMO_USER_ID=
